@startuml
!pragma layout smetana
hide empty members
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle

package "Frontend" {
  class TelemetryChartComponent <<Angular Material component>>
  class TelemetryChartStore <<signal store>>
  class TelemetryLiveClient <<signalr client>>
  class TelemetryHistoryClient <<http client>>
}

package "Contracts" {
  class TelemetryPoint
  class TelemetryHistoryCursor
  class TelemetryHistoryPage
  class LoadedWindow
  class Viewport
  class LiveSubscriptionState
  enum ChartMode
  enum HistoryDirection
}

TelemetryChartComponent --> TelemetryChartStore : select telemetry / scrub / resume live
TelemetryChartComponent --> TelemetryChartComponent : render on animation frame
TelemetryChartStore --> TelemetryLiveClient : subscribe / unsubscribe
TelemetryChartStore --> TelemetryHistoryClient : fetch history page
TelemetryChartStore o-- TelemetryPoint : ordered timeline
TelemetryChartStore o-- LoadedWindow : loaded history
TelemetryChartStore --> LiveSubscriptionState
TelemetryChartStore --> Viewport
TelemetryChartStore --> ChartMode
TelemetryHistoryClient --> TelemetryHistoryPage
TelemetryHistoryPage o-- TelemetryHistoryCursor : previous / next
TelemetryHistoryPage "1" o-- "*" TelemetryPoint : items
TelemetryHistoryCursor --> HistoryDirection
@enduml
