@startuml
participant TelemetryGeneratorWorker
participant TelemetryDispatchWorker
participant TelemetryHub
participant TelemetryRepository
database "Telemetry DB" as Db
actor Browser
participant TelemetryController

Browser -> TelemetryHub : SubscribeTelemetry(telemetryId)

loop every 50 ms for each configured telemetryId
  TelemetryGeneratorWorker -> TelemetryDispatchWorker : TelemetrySample via channel
  TelemetryDispatchWorker -> TelemetryHub : telemetrySample(telemetry group)
  TelemetryHub --> Browser : live sample for subscribed telemetryId
  TelemetryDispatchWorker -> TelemetryDispatchWorker : add sample to batch
end

loop every 100 ms or 256 samples
  TelemetryDispatchWorker -> TelemetryRepository : insert batch
  TelemetryRepository -> Db : append rows
  Db --> TelemetryRepository : commit
end

Browser -> TelemetryController : GET /api/telemetry/history
TelemetryController -> TelemetryRepository : read history page
TelemetryRepository -> Db : cursor query
Db --> TelemetryRepository : ordered rows
TelemetryRepository --> TelemetryController : TelemetryHistoryPageDto
TelemetryController --> Browser : page dto
@enduml
