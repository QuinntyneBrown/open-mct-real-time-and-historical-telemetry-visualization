@startuml
participant TelemetryGenerationWorker
participant TelemetryFanOutWorker
participant TelemetryPersistenceWorker
participant TelemetryBroadcastWorker
participant TelemetryHub
database "Telemetry DB" as Db
actor Browser
participant TelemetryController
participant TelemetryHistoryService

loop every 50 ms
  TelemetryGenerationWorker -> TelemetryFanOutWorker : TelemetrySample
  TelemetryFanOutWorker -> TelemetryPersistenceWorker : enqueue sample
  TelemetryFanOutWorker -> TelemetryBroadcastWorker : enqueue sample
  TelemetryBroadcastWorker -> TelemetryHub : telemetrySample(metric group)
  TelemetryHub --> Browser : live sample
end

loop every 100 ms or 256 samples
  TelemetryPersistenceWorker -> Db : batched insert
  Db --> TelemetryPersistenceWorker : rows committed
end

Browser -> TelemetryController : GET /api/telemetry/history
TelemetryController -> TelemetryHistoryService : getHistory(request)
TelemetryHistoryService -> Db : cursor query
Db --> TelemetryHistoryService : ordered samples
TelemetryHistoryService --> TelemetryController : TelemetryHistoryPageDto
TelemetryController --> Browser : page dto
@enduml
