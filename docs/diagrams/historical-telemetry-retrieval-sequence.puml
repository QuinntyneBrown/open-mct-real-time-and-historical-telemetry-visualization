@startuml
actor User
participant TelemetryChartComponent
participant TelemetryChartStore
participant TelemetryLiveClient
participant TelemetryHub
participant TelemetryHistoryClient
participant TelemetryController
database "Telemetry DB" as Db

User -> TelemetryChartComponent : choose telemetryId
TelemetryChartComponent -> TelemetryChartStore : setActiveTelemetryId(telemetryId)
TelemetryChartStore -> TelemetryLiveClient : subscribe(telemetryId)
TelemetryLiveClient -> TelemetryHub : SubscribeTelemetry(telemetryId)
TelemetryHub --> TelemetryLiveClient : subscribed
TelemetryLiveClient --> TelemetryChartStore : telemetrySample(telemetryId)
TelemetryChartStore -> TelemetryChartStore : merge live sample
TelemetryChartStore --> TelemetryChartComponent : visible points
TelemetryChartComponent -> TelemetryChartComponent : requestAnimationFrame()
TelemetryChartComponent -> TelemetryChartComponent : chart.update("none")

User -> TelemetryChartComponent : scrub to time range
TelemetryChartComponent -> TelemetryChartStore : setViewport(range)
TelemetryChartStore -> TelemetryChartStore : check loaded windows

alt viewport already loaded
  TelemetryChartStore --> TelemetryChartComponent : visible points
  TelemetryChartComponent -> TelemetryChartComponent : requestAnimationFrame()
  TelemetryChartComponent -> TelemetryChartComponent : chart.update("none")
else history gap exists
  TelemetryChartStore -> TelemetryHistoryClient : fetchPage(query)
  TelemetryHistoryClient -> TelemetryController : GET /api/telemetry/history
  TelemetryController -> Db : cursor query
  Db --> TelemetryController : ordered rows
  TelemetryController --> TelemetryHistoryClient : page dto
  TelemetryHistoryClient --> TelemetryChartStore : Observable<TelemetryHistoryPage>
  TelemetryChartStore -> TelemetryChartStore : merge timeline and loaded windows
  TelemetryChartStore --> TelemetryChartComponent : visible points
  TelemetryChartComponent -> TelemetryChartComponent : requestAnimationFrame()
  TelemetryChartComponent -> TelemetryChartComponent : chart.update("none")
end
@enduml
